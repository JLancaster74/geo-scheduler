# ─────────────────────────────────────────────────────
# GeoScheduler — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# ── Google Maps Geocoding API ─────────────────────────
# Get from: console.cloud.google.com → APIs → Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Twilio SMS ────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number that sends SMS (must be SMS-enabled)
# Format: +15551234567
TWILIO_PHONE_NUMBER=+15551234567

# Your personal callback number shown in SMS messages
YOUR_PHONE_NUMBER=+16627821777

# ── Bland.ai ──────────────────────────────────────────
# Get from: app.bland.ai → Settings → API Keys
BLAND_API_KEY=your_bland_api_key_here

# Your full Railway server URL (get this after deploying)
# Example: https://geo-scheduler-production-a4b2.up.railway.app
SERVER_URL=https://your-railway-url-here.up.railway.app

# ── Server ────────────────────────────────────────────
PORT=3001
